# JWT Configuration
JWT_SECRET=your-secret-jwt-key-here-change-in-production

# Admin Creation Bypass Secret
ADMIN_SECRET=your-admin-secret-key-here-change-in-production

# Server Port (optional, defaults to 5000)
PORT=5000

# Database URL (if using MongoDB)
MONGODB_URI=mongodb://localhost:27017/parkfinder

# Email Service Configuration (if applicable)
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password
